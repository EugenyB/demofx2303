<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mainfx.MainController">
    <center>
        <AnchorPane prefHeight="400.0" prefWidth="600.0">
            <TableView fx:id="studentTable" layoutX="14.0" layoutY="14.0" prefHeight="380.0" prefWidth="326.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.topAnchor="10.0">
                <columns>
                    <TableColumn fx:id="idColumn" prefWidth="50.0" text="№" />
                    <TableColumn fx:id="nameColumn" prefWidth="150.0" text="Name" />
                    <TableColumn fx:id="ageColumn" prefWidth="50.0" text="Age" />
                    <TableColumn fx:id="ratingColumn" prefWidth="70.0" text="Rating" />
                </columns>
            </TableView>
        </AnchorPane>
    </center>
    <top>
        <VBox BorderPane.alignment="CENTER">
            <MenuBar prefHeight="10.0" prefWidth="600.0">
                <Menu mnemonicParsing="false" text="File">
                    <MenuItem mnemonicParsing="false" text="Close" />
                </Menu>
                <Menu mnemonicParsing="false" text="Edit">
                    <MenuItem mnemonicParsing="false" text="Delete" />
                </Menu>
                <Menu mnemonicParsing="false" text="Help">
                    <MenuItem mnemonicParsing="false" text="About" />
                </Menu>
            </MenuBar>
            <ToolBar prefHeight="40.0" prefWidth="200.0">
                <Button mnemonicParsing="false" text="Draw" />
                <Button mnemonicParsing="false" onAction="#about" text="About" />
            </ToolBar>
        </VBox>
    </top>
    <right>
        <AnchorPane prefHeight="400.0" prefWidth="155.0" BorderPane.alignment="CENTER">
            <Label layoutX="10.0" layoutY="10.0" text="id:" />
            <TextField fx:id="idField" layoutX="10.0" layoutY="25.0" prefHeight="25.0" prefWidth="132.0" />
            <Label layoutX="10.0" layoutY="55.0" text="Name:" />
            <TextField fx:id="nameField" layoutX="10.0" layoutY="70.0" prefHeight="25.0" prefWidth="132.0" />
            <Label layoutX="10.0" layoutY="100.0" text="Age:" />
            <TextField fx:id="ageField" layoutX="10.0" layoutY="115.0" prefHeight="25.0" prefWidth="132.0" />
            <Label layoutX="10.0" layoutY="145.0" text="Rating:" />
            <TextField fx:id="ratingField" layoutX="10.0" layoutY="160.0" prefHeight="25.0" prefWidth="132.0" />
            <Button layoutX="10.0" layoutY="188.0" mnemonicParsing="false" onAction="#addStudent" text="Додати" />
        </AnchorPane>
    </right>
</BorderPane>
